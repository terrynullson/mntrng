# Local/dev baseline template for `docker compose`.
# Copy to `.env` and fill required values.
# Production template: `deploy/env.prod.example` (minimal) or `deploy/env.prod.full.example`.

########################################
# Core mode and DB (required)          #
########################################
# [required][all][not secret]
APP_ENV=development

# [required][all][sensitive]
POSTGRES_DB=hls_monitoring
POSTGRES_USER=app
POSTGRES_PASSWORD=CHANGE_ME_LOCAL_DB_PASSWORD
POSTGRES_PORT=5432

# [required for local run outside docker][dev][sensitive]
# DATABASE_URL=postgres://app:CHANGE_ME_LOCAL_DB_PASSWORD@localhost:5432/hls_monitoring?sslmode=disable

########################################
# API + frontend routing               #
########################################
# [optional][all][not secret]
API_PORT=8080
FRONTEND_PORT=3000
REDIS_ADDR=redis:6379
INTERNAL_API_BASE_URL=http://api:8080
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

########################################
# Security defaults                    #
########################################
# [optional][all][not secret]
BOOTSTRAP_SEED_ENABLED=false
API_METRICS_PUBLIC=false
TRUST_PROXY_HEADERS=false
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH=/
AUTH_ACCESS_COOKIE_NAME=hm_access_token
AUTH_REFRESH_COOKIE_NAME=hm_refresh_token
CORS_ALLOWED_ORIGINS=http://localhost:3000

########################################
# API limits / DB pool                 #
########################################
# [optional][all][not secret]
API_HSTS_ENABLED=false
API_READ_HEADER_TIMEOUT_SEC=5
API_READ_TIMEOUT_SEC=15
API_WRITE_TIMEOUT_SEC=30
API_IDLE_TIMEOUT_SEC=60
API_MAX_HEADER_BYTES=1048576
API_MAX_BODY_BYTES=1048576
RATE_LIMIT_AUTH_PER_MIN=10
DB_MAX_OPEN_CONNS=30
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_MIN=30
DB_CONN_MAX_IDLE_TIME_MIN=10

########################################
# Auth                                 #
########################################
# [optional][all][not secret]
AUTH_ACCESS_TTL_MIN=15
AUTH_REFRESH_TTL_DAYS=30
AUTH_TELEGRAM_MAX_AGE_SEC=600

########################################
# Worker runtime + checks              #
########################################
# [optional][all][not secret unless marked]
WORKER_HEARTBEAT_SEC=15
WORKER_JOB_TIMEOUT_SEC=30
WORKER_DB_RETRY_MAX=2
WORKER_DB_RETRY_BACKOFF_MS=500
WORKER_METRICS_PORT=9091

# [required in production][prod][sensitive]
# Keep non-empty strong random token (32+ chars). Empty value exposes worker metrics publicly.
WORKER_METRICS_TOKEN=

WORKER_RUNNING_JOB_STALE_SEC=300
WORKER_ALLOW_PRIVATE_STREAM_URLS=false
PLAYLIST_TIMEOUT_MS=3000
SEGMENT_TIMEOUT_MS=5000
SEGMENTS_SAMPLE_COUNT=3
FRESHNESS_WARN_SEC=10
FRESHNESS_FAIL_SEC=30
FREEZE_WARN_SEC=2
FREEZE_FAIL_SEC=5
BLACKFRAME_WARN_RATIO=0.9
BLACKFRAME_FAIL_RATIO=0.98
EFFECTIVE_BITRATE_WARN_RATIO=0.7
EFFECTIVE_BITRATE_FAIL_RATIO=0.4

########################################
# Alerts + Telegram                    #
########################################
# [optional][all][sensitive for tokens/chat ids]
ALERT_FAIL_STREAK=2
ALERT_COOLDOWN_MIN=10
ALERT_SEND_RECOVERED=false
TELEGRAM_HTTP_TIMEOUT_MS=5000
TELEGRAM_SEND_RETRY_MAX=2
TELEGRAM_SEND_RETRY_BACKOFF_MS=500
TELEGRAM_BOT_TOKEN_DEFAULT=
SUPER_ADMIN_TELEGRAM_CHAT_ID=

########################################
# AI / diagnostics / retention         #
########################################
# [optional][all][sensitive for API key]
RETENTION_TTL_DAYS=30
RETENTION_CLEANUP_INTERVAL_MIN=60
RETENTION_CLEANUP_BATCH_SIZE=100
# AI incident analysis: disabled by default. When true, stub analyzer runs (no real LLM/provider yet).
# See docs/ai_incident_contract.md and README "Partial / stubbed".
AI_INCIDENT_ENABLED=false
AI_INCIDENT_API_KEY=
INCIDENT_SCREENSHOT_INTERVAL_MIN=10
DIAG_CAPTURE_TIMEOUT_SEC=6
DIAG_FREEZE_INTERVAL_SEC=2
DIAG_FREEZE_DIFF_THRESHOLD=0.01
OTEL_EXPORTER_OTLP_ENDPOINT=

########################################
# Scheduler                            #
########################################
# [optional][all][sensitive for token]
SCHEDULER_API_BASE_URL=http://api:8080
SCHEDULER_ACCESS_TOKEN=
SCHEDULER_INTERVAL_MIN=30
SCHEDULER_ENABLED=false

# SCHEDULER_ACCESS_TOKEN is usually access_token from /api/v1/auth/login.
# Token expires according to AUTH_ACCESS_TTL_MIN.

########################################
# Optional local extras                #
########################################
# [optional][all][not secret unless marked]
# APP_DATA_DIR=/data
DEV_LOG_TELEGRAM_ENABLED=false
DEV_LOG_TELEGRAM_TOKEN=
DEV_LOG_TELEGRAM_CHAT_ID=
