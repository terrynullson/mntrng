

# Full production environment template.
# Copy to .env.prod and replace values marked with CHANGE_ME.

############################
# 1) Public domain and TLS #
############################
APP_ENV=production
DOMAIN=d-ableev.ru
CADDY_EMAIL=

###########################
# 2) Database (required)  #
###########################
POSTGRES_DB=hls_monitoring
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me_local_password
POSTGRES_PORT=5432

#############################################
# 3) Core service routing and runtime ports #
#############################################
API_PORT=8080
FRONTEND_PORT=3000
REDIS_ADDR=redis:6379
INTERNAL_API_BASE_URL=http://api:8080
NEXT_PUBLIC_API_BASE_URL=https://d-ableev.ru

###################################################
# 4) Security-by-default (keep as-is for prod)    #
###################################################
BOOTSTRAP_SEED_ENABLED=false
API_METRICS_PUBLIC=false
TRUST_PROXY_HEADERS=true
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=strict
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH=/
AUTH_ACCESS_COOKIE_NAME=hm_access_token
AUTH_REFRESH_COOKIE_NAME=hm_refresh_token
CORS_ALLOWED_ORIGINS=https://d-ableev.ru

##########################################
# 5) API hardening / performance limits  #
##########################################
API_HSTS_ENABLED=true
API_READ_HEADER_TIMEOUT_SEC=5
API_READ_TIMEOUT_SEC=15
API_WRITE_TIMEOUT_SEC=30
API_IDLE_TIMEOUT_SEC=60
API_MAX_HEADER_BYTES=1048576
API_MAX_BODY_BYTES=1048576
RATE_LIMIT_AUTH_PER_MIN=10
DB_MAX_OPEN_CONNS=30
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_MIN=30
DB_CONN_MAX_IDLE_TIME_MIN=10

###########################
# 6) Auth token settings  #
###########################
AUTH_ACCESS_TTL_MIN=15
AUTH_REFRESH_TTL_DAYS=30
AUTH_TELEGRAM_MAX_AGE_SEC=600

##############################
# 7) Worker base config      #
##############################
WORKER_HEARTBEAT_SEC=15
WORKER_JOB_TIMEOUT_SEC=30
WORKER_DB_RETRY_MAX=2
WORKER_DB_RETRY_BACKOFF_MS=500
WORKER_METRICS_PORT=9091
WORKER_METRICS_TOKEN=
WORKER_RUNNING_JOB_STALE_SEC=300
WORKER_ALLOW_PRIVATE_STREAM_URLS=false

###########################################
# 8) Stream checks thresholds (defaults)  #
###########################################
PLAYLIST_TIMEOUT_MS=3000
SEGMENT_TIMEOUT_MS=5000
SEGMENTS_SAMPLE_COUNT=3
FRESHNESS_WARN_SEC=30
FRESHNESS_FAIL_SEC=90
FREEZE_WARN_SEC=15
FREEZE_FAIL_SEC=45
BLACKFRAME_WARN_RATIO=0.9
BLACKFRAME_FAIL_RATIO=0.98
EFFECTIVE_BITRATE_WARN_RATIO=0.7
EFFECTIVE_BITRATE_FAIL_RATIO=0.4

##################################
# 9) Alerting + Telegram (opt)   #
##################################
ALERT_FAIL_STREAK=2
ALERT_COOLDOWN_MIN=10
ALERT_SEND_RECOVERED=false
TELEGRAM_HTTP_TIMEOUT_MS=5000
TELEGRAM_SEND_RETRY_MAX=2
TELEGRAM_SEND_RETRY_BACKOFF_MS=500
TELEGRAM_BOT_TOKEN_DEFAULT=
SUPER_ADMIN_TELEGRAM_CHAT_ID=

###########################################
# 10) Retention / AI / diagnostics (opt)  #
###########################################
RETENTION_TTL_DAYS=30
RETENTION_CLEANUP_INTERVAL_MIN=60
RETENTION_CLEANUP_BATCH_SIZE=100
AI_INCIDENT_API_KEY=
INCIDENT_SCREENSHOT_INTERVAL_MIN=10
DIAG_CAPTURE_TIMEOUT_SEC=6
DIAG_FREEZE_INTERVAL_SEC=2
DIAG_FREEZE_DIFF_THRESHOLD=0.01
OTEL_EXPORTER_OTLP_ENDPOINT=

############################################
# 11) DevLog в Telegram (post-commit hook)  #
############################################
DEV_LOG_TELEGRAM_ENABLED=true
DEV_LOG_TELEGRAM_TOKEN=
DEV_LOG_TELEGRAM_CHAT_ID=

# Scheduler: периодическая постановка check-jobs для активных потоков (см. README)
SCHEDULER_API_BASE_URL=http://api:8080
SCHEDULER_ACCESS_TOKEN=
SCHEDULER_INTERVAL_MIN=30
SCHEDULER_ENABLED=true

# Для локального запуска API/Worker без Docker задайте DATABASE_URL.
# В Docker Compose URL собирается из POSTGRES_* автоматически.
# DATABASE_URL=postgres://app:PASSWORD@localhost:5432/hls_monitoring?sslmode=disable

# Опционально: каталог данных (скриншоты, инциденты). API и Worker. По умолчанию /data.
# APP_DATA_DIR=/data

# Scheduler token note:
# SCHEDULER_ACCESS_TOKEN is usually an access_token from /api/v1/auth/login.
# It expires according to AUTH_ACCESS_TTL_MIN. If you do not need auto-checks, set SCHEDULER_ENABLED=false.
