# Бот «День, если что» (@shoza_den)
# Скопируй в .env и заполни значения.

# Telegram
SHOZA_BOT_TOKEN=
SHOZA_CHANNEL_ID=@shoza_den
SHOZA_ADMIN_CHAT_ID=

# Режим: simple_auto (этап 1) | approval | approval_with_timeout (этап 2)
SHOZA_PUBLISH_MODE=simple_auto
SHOZA_APPROVAL_TIMEOUT_MINUTES=120

# AI: simple | yandex | deepseek | local
SHOZA_AI_PROVIDER=simple

# Провайдеры (для этапа 2)
SHOZA_YANDEX_API_KEY=
SHOZA_YANDEX_FOLDER_ID=
SHOZA_DEEPSEEK_API_KEY=
SHOZA_LOCAL_AI_BASE_URL=http://localhost:11434
SHOZA_LOCAL_AI_MODEL=

# Расписание (локальное время)
SHOZA_POST_HOUR=7
SHOZA_POST_MINUTE=0

# Папка для БД (необязательно). Пусто = telegram-day-bot/data/ создаётся сама при первом запуске.
# В ней только файл posts.db — история постов и статусы одобрения.
SHOZA_DATA_DIR=
