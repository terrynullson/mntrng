APP_ENV=production

# Public domain and TLS email (Let's Encrypt via Caddy)
DOMAIN=example.com
CADDY_EMAIL=ops@example.com

# Database
POSTGRES_DB=hls_monitoring
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me_to_strong_password
POSTGRES_PORT=5432

# Security defaults
BOOTSTRAP_SEED_ENABLED=false
API_METRICS_PUBLIC=false
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=strict
TRUST_PROXY_HEADERS=true

# API/runtime limits
API_MAX_BODY_BYTES=1048576
API_MAX_HEADER_BYTES=1048576
API_READ_HEADER_TIMEOUT_SEC=5
API_READ_TIMEOUT_SEC=15
API_WRITE_TIMEOUT_SEC=30
API_IDLE_TIMEOUT_SEC=60
API_HSTS_ENABLED=true

# Frontend routing
INTERNAL_API_BASE_URL=http://api:8080
NEXT_PUBLIC_API_BASE_URL=https://example.com

# Worker metrics (keep private token strong)
WORKER_METRICS_PORT=9091
WORKER_METRICS_TOKEN=CHANGE_ME_LONG_RANDOM_TOKEN_32_CHARS_MIN

# Scheduler (recommended: keep disabled until token rotation process is in place)
SCHEDULER_ENABLED=false
SCHEDULER_API_BASE_URL=http://api:8080
SCHEDULER_ACCESS_TOKEN=

